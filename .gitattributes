# Force LF line endings for all Ansible/Linux files
* text=auto

*.yml    text eol=lf
*.yaml   text eol=lf
*.j2     text eol=lf
*.ini    text eol=lf
*.cfg    text eol=lf
*.sh     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.js     text eol=lf
Jenkinsfile text eol=lf

# Binary files
*.pem    binary
*.png    binary
*.jpg    binary
*.gz     binary

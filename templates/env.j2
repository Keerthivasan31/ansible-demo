# {{ ansible_managed }}
# =============================================================
#  .env template  –  Application environment variables
#  Host: {{ inventory_hostname }}
#  ⚠ Contains sensitive values – managed by Ansible Vault
# =============================================================

NODE_ENV={{ node_env }}
PORT={{ app_port }}
INSTANCE_ID={{ host_alias }}

{% for key, value in app_env_vars.items() %}
{{ key }}={{ value }}
{% endfor %}

# Vault-encrypted secrets (injected at deploy time)
APP_SECRET_KEY={{ vault_app_secret_key | default('CHANGE_ME') }}
DB_PASSWORD={{ vault_db_password | default('CHANGE_ME') }}
